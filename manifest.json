{
  "manifest_version": 3,
  "name": "PopTranslate",
  "version": "1.0.0",
  "description": "Highlight any text on any webpage to see an instant translation in a small floating popup.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://api.mymemory.translated.net/*"],
  "action": {
    "default_title": "PopTranslate settings",
    "default_popup": "settings.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
